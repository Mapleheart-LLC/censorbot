# Copy this file to .env and fill in your values
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: comma-separated list of channel IDs to monitor (leave empty to monitor all channels)
MONITORED_CHANNELS=

# Pixel block size for pixelation (default: 20)
PIXEL_BLOCK_SIZE=20

# Minimum NudeNet detection confidence 0.0–1.0 (default: 0.0 – accept all detections)
MIN_CONFIDENCE=0.0

# Comma-separated NudeNet labels to censor; leave empty to use the built-in defaults
# Example: FEMALE_BREAST_EXPOSED,MALE_GENITALIA_EXPOSED
CENSOR_CLASSES=

# Run NudeNet detection every N video frames (default: 1 – every frame).
# Increase for faster processing of long videos at the cost of some accuracy.
VIDEO_FRAME_SAMPLE_RATE=1

# Maximum size (in MB) for a censored file before it is dropped and a warning
# is posted instead (default: 8.0 – Discord's standard upload limit)
MAX_FILE_MB=8.0

# Send the original author a DM explaining why their message was removed (default: true)
DM_ON_CENSOR=true

# Channel ID for a moderator audit-log (leave empty to disable)
LOG_CHANNEL_ID=

# Port for the built-in HTTP health-check endpoint; set to 0 to disable (default: 8080)
HEALTH_PORT=8080

