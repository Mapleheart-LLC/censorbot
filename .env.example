# Copy this file to .env and fill in your values
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: comma-separated list of channel IDs to monitor (leave empty to monitor all channels)
MONITORED_CHANNELS=

# Censoring mode: pixelate or blur (default: pixelate)
CENSOR_MODE=pixelate

# Pixel block size for pixelation (default: 20)
PIXEL_BLOCK_SIZE=20

# Blur radius for blur mode (default: 20)
BLUR_RADIUS=20
